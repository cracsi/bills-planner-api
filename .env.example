# Server
PORT=3000

# Database (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=bills_planner

# WARNING: never set true against a database with real data outside local dev.
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Auth (added once we build the auth module)
JWT_SECRET=change-me-in-local-env
JWT_EXPIRES_IN=1d

# Email (Resend) — added once we build the reminders/scheduler feature
RESEND_API_KEY=
